# TrendFi ML Service Environment Variables

# Reddit API Credentials
# Go to: https://www.reddit.com/prefs/apps
# Create a script app and copy the credentials below:
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=TrendiFi-MLService/1.0 (by your_reddit_username)

# Service Configuration
ML_SERVICE_PORT=8000
ENVIRONMENT=development

# Optional: Redis configuration (for future caching layer)
# REDIS_URL=redis://redis:6379/0
